@{
  ViewData["Title"] = "Home Page";
}

<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Hệ thống dự đoán điểm số học sinh</title>
  <link rel="stylesheet" href="~/css/styles.css" />
  <script src="~/js/script.js" defer></script>
</head>

<body>
  <header class="hero">
    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">ỨNG DỤNG KHAI THÁC DỮ LIỆU</p>
        <h1>Hệ thống dự đoán điểm số học sinh</h1>
        <p class="hero-text">
          Nhập các chỉ số học tập để hệ thống gửi dữ liệu đến backend, nhận kết quả dự đoán
          và hiển thị đánh giá học tập ngay trên giao diện.
        </p>
        <div class="hero-actions">
          <a class="btn btn-light" href="#prediction-form">Dự đoán ngay</a>
          <a class="btn btn-outline" href="#history-section">Xem lịch sử</a>
        </div>
      </div>

      <div class="hero-card">
        <div class="hero-metric">
          <span>Loại bài toán</span>
          <strong>Hồi quy</strong>
        </div>
        <div class="hero-metric">
          <span>API mặc định</span>
          <strong id="apiEndpointLabel">POST /predict</strong>
        </div>
        <div class="hero-metric full-width">
          <span>Trạng thái kết nối</span>
          <strong id="connectionBadge">Sẵn sàng gửi yêu cầu</strong>
        </div>
      </div>
    </div>
  </header>

  <main class="container page-content">
    <section class="grid two-col">
      <section class="card panel-card">
        <div class="card-head">
          <div>
            <h2>Thông tin đầu vào</h2>
            <p>Nhập dữ liệu học tập của học sinh trước khi gửi đến backend</p>
          </div>
          <span class="badge badge-soft" id="formStateBadge">Sẵn sàng</span>
        </div>

        <form id="prediction-form" class="form-panel" novalidate>
          <div class="field-grid">
            <div class="field-group">
              <label for="studentName">Họ và tên học sinh</label>
              <input type="text" id="studentName" name="studentName" placeholder="Nguyễn Văn A" autocomplete="name" />
              <small class="error-text" id="studentNameError"></small>
            </div>

            <div class="field-group">
              <label for="className">Lớp</label>
              <input type="text" id="className" name="className" placeholder="12A1" />
              <small class="error-text" id="classNameError"></small>
            </div>

            <div class="field-group">
              <label for="studyTime">Mức thời gian tự học</label>
              <select id="studyTime" name="studyTime">
                <option value="">Chọn mức thời gian học</option>
                <option value="1">1 - Dưới 2 giờ/tuần</option>
                <option value="2">2 - Từ 2 đến 5 giờ/tuần</option>
                <option value="3">3 - Từ 5 đến 10 giờ/tuần</option>
                <option value="4">4 - Trên 10 giờ/tuần</option>
              </select>
              <small class="error-text" id="studyTimeError"></small>
            </div>

            <div class="field-group">
              <label for="absences">Số buổi vắng học</label>
              <input type="number" id="absences" name="absences" min="0" max="100" step="1" placeholder="4" />
              <small class="error-text" id="absencesError"></small>
            </div>

            <div class="field-group">
              <label for="failures">Số lần chưa đạt trước đó</label>
              <input type="number" id="failures" name="failures" min="0" max="10" step="1" placeholder="0" />
              <small class="error-text" id="failuresError"></small>
            </div>
            <div class="field-group">
              <label for="schoolsup">Hỗ trợ từ nhà trường</label>
              <select id="schoolsup" name="schoolsup">
                <option value="">Chọn trạng thái hỗ trợ</option>
                <option value="1">Có</option>
                <option value="0">Không</option>
              </select>
              <small class="error-text" id="schoolsupError"></small>
            </div>

            <div class="field-group">
              <label for="famsup">Hỗ trợ từ gia đình</label>
              <select id="famsup" name="famsup">
                <option value="">Chọn trạng thái hỗ trợ</option>
                <option value="1">Có</option>
                <option value="0">Không</option>
              </select>
              <small class="error-text" id="famsupError"></small>
            </div>

            <div class="field-group">
              <label for="internet">Có Internet tại nhà</label>
              <select id="internet" name="internet">
                <option value="">Chọn tình trạng Internet</option>
                <option value="1">Có</option>
                <option value="0">Không</option>
              </select>
              <small class="error-text" id="internetError"></small>
            </div>

            <div class="field-group field-group-full">
              <label for="note">Ghi chú</label>
              <textarea id="note" name="note" rows="4"
                        placeholder="Thông tin thêm về tình hình học tập nếu cần"></textarea>
            </div>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary" id="submitBtn">Gửi yêu cầu dự đoán</button>
            <button type="reset" class="btn btn-ghost" id="resetBtn">Làm mới</button>
          </div>
        </form>
      </section>

      <section class="card panel-card result-card" id="result-section">
        <div class="card-head">
          <div>
            <h2>Kết quả dự đoán</h2>
            <p>Kết quả được cập nhật sau khi backend xử lý xong</p>
          </div>
          <span class="badge" id="requestStatusBadge">Chưa gửi</span>
        </div>

        <div class="result-panel empty-state" id="resultPanel">
          <div class="score-wrapper">
            <p class="score-label">Điểm dự đoán</p>
            <div class="score-value" id="predictedScore">--</div>
            <p class="score-subvalue">Thang 10: <span id="predictedScore10">--</span></p>
          </div>

          <div class="result-meta">
            <div class="summary-box">
              <h3>Đánh giá</h3>
              <p class="result-status" id="scoreStatus">Chưa có dữ liệu</p>
              <p class="result-desc" id="scoreDesc">Gửi biểu mẫu để xem kết quả từ backend.</p>
            </div>

            <div class="summary-box">
              <h3>Khuyến nghị</h3>
              <p id="feedbackText">Hệ thống sẽ hiển thị nhận xét sau khi nhận phản hồi thành công từ dịch vụ dự đoán.
              </p>
            </div>
          </div>
        </div>

        <div class="summary-box input-summary">
          <h3>Tóm tắt dữ liệu lần gần nhất</h3>
          <div class="summary-grid">
            <div class="summary-item"><span>Học sinh</span><strong id="summaryStudent">--</strong></div>
            <div class="summary-item"><span>Lớp</span><strong id="summaryClass">--</strong></div>
            <div class="summary-item"><span>studytime</span><strong id="summaryStudyTime">--</strong></div>
            <div class="summary-item"><span>absences</span><strong id="summaryAbsences">--</strong></div>
            <div class="summary-item"><span>failures</span><strong id="summaryFailures">--</strong></div>
            <div class="summary-item"><span>schoolsup</span><strong id="summarySchoolsup">--</strong></div>
            <div class="summary-item"><span>famsup</span><strong id="summaryFamsup">--</strong></div>
            <div class="summary-item"><span>internet</span><strong id="summaryInternet">--</strong></div>
            <div class="summary-item"><span>Yêu cầu lúc</span><strong id="summaryRequestedAt">--</strong></div>
          </div>
        </div>
      </section>
    </section>

    <section class="grid two-col meta-grid">
      <section class="card panel-card compact-card">
        <div class="card-head">
          <div>
            <h2>Trạng thái hệ thống</h2>
            <p>Theo dõi tiến trình gọi API và phản hồi từ backend</p>
          </div>
        </div>
        <div class="status-board">
          <div class="status-row">
            <span>API endpoint</span>
            <strong id="apiEndpointText">/predict</strong>
          </div>
          <div class="status-row">
            <span>Phương thức</span>
            <strong>POST</strong>
          </div>
          <div class="status-row">
            <span>Content-Type</span>
            <strong>application/json</strong>
          </div>
          <div class="status-banner" id="formStatus" aria-live="polite">Sẵn sàng gửi yêu cầu.</div>
        </div>
      </section>

      <section class="card panel-card compact-card">
        <div class="card-head">
          <div>
            <h2>Dữ liệu gửi đi</h2>
            <p>Payload JSON của lần gửi gần nhất</p>
          </div>
        </div>
        <div class="json-box">
          <pre id="payloadPreview">{
            "studytime": null,
            "absences": null,
            "failures": null,
            "schoolsup": null,
            "famsup": null,
            "internet": null
            }</pre>
          </div>
        </section>
      </section>

      <section class="card panel-card history-card" id="history-section">
        <div class="card-head">
          <div>
            <h2>Lịch sử dự đoán gần đây</h2>
            <p>Lưu tạm trên trình duyệt để tiện theo dõi khi demo và kiểm thử</p>
          </div>
        </div>

        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Thời gian</th>
                <th>Học sinh</th>
                <th>Lớp</th>
                <th>studytime</th>
                <th>schoolsup</th>
                <th>famsup</th>
                <th>internet</th>
                <th>Dự đoán</th>
              </tr>
            </thead>
            <tbody id="historyBody">
              <tr class="empty-row">
                <td colspan="8">Chưa có lần dự đoán nào.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </body>

</html>
